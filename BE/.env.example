# --- CLOVA OCR (Naver Cloud Platform - AI Application Service) ---
# 콘솔에서 도메인(General/Receipt)을 만들면 발급되는 값
CLOVA_OCR_INVOKE_URL=https://xxxxxxxxxx.apigw.ntruss.com/custom/v1/xxxxx/xxxxxxxx/general
CLOVA_OCR_SECRET_KEY=your-ocr-secret-key

# --- CLOVA Studio (HyperCLOVA X, OpenAI-compatible endpoint) ---
# Test API Key(개인 실험용)든 Service API Key(등록된 서비스 앱용)든 URL은 동일하게 이거 하나만 씀.
# 테스트/서비스 구분은 콘솔에서 발급하는 키의 "종류"로만 결정됨 (testapp/serviceapp 경로 구분 없음).
CLOVA_STUDIO_API_KEY=your-clova-studio-api-key
CLOVA_STUDIO_API_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai
CLOVA_STUDIO_CHAT_MODEL=HCX-005
CLOVA_STUDIO_EMBEDDING_MODEL=clir-emb-dolphin

# --- App ---
RAG_INDEX_PATH=./data/food_index.pkl
CORS_ORIGINS=http://localhost:5173
